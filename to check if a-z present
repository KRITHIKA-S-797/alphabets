
#include <iostream>
using namespace std;
int main(){
    char str[100001];
    cin>>str;
    int flag=0;
    for(int i=0;str[i]!='0';i++){
        if(str[i]>='a' && str[i]<='z'){
            flag=flag|(1<<(str[i]-'a'));
        }
       
    }
    if((flag==(1<<26)-1)){
        cout<<"yes";
    }
    else{
        cout<<"no";
    }
}
